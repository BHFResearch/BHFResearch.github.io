---
import Search from '../components/Search.astro';
const { title = "Better Health Facts" } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />

  <meta
    name="viewport"
    content="width=device-width, initial-scale=1"
  />

  <meta
    name="description"
    content={Astro.props.description || "Better Health Research Articles"}
  />

  <link rel="canonical" href={Astro.url} />

  <meta property="og:type" content="article" />
  <meta property="og:title" content={Astro.props.title} />
  <meta property="og:description" content={Astro.props.description} />
  <meta property="og:url" content={Astro.url} />

  <!-- ADSENSE -->
  <script
    async
    crossorigin="anonymous"
    src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-0770728525587553">
  </script>

  <!-- UMAMI -->
  <script
    defer
    src="https://cloud.umami.is/script.js"
    data-website-id="e41c2d07-e2b3-433b-a54f-53db54317699">
  </script>

  <!-- GA4 -->
  <script
    async
    src="https://www.googletagmanager.com/gtag/js?id=G-08PH0RXVZP">
  </script>

  <script>
    window.dataLayer = window.dataLayer || [];

    function gtag(){dataLayer.push(arguments);}

    gtag('js', new Date());

    gtag('config', 'G-08PH0RXVZP');
  </script>

  <style>

    :root {
      --bg: #020617;
      --surface: #0f172a;
      --surface-2: #111827;
      --text: #f8fafc;
      --muted: #94a3b8;
      --primary: #38bdf8;
      --border: rgba(255,255,255,0.08);
      --radius: 22px;
    }

    * {
      box-sizing: border-box;
    }

    body {
      margin: 0;

      font-family:
        Inter,
        system-ui,
        sans-serif;

      background:
        radial-gradient(
          circle at top,
          #0f172a,
          #020617 60%
        );

      color: var(--text);

      overflow-x: hidden;
    }

    a {
      text-decoration: none;
      color: var(--primary);
    }

    /* HEADER */

    header {
      background: var(--primary);

      color: white;

      padding: 12px 16px;

      position: sticky;
      top: 0;
      z-index: 1000;

      overflow-x: hidden;
    }

    .header-inner {
      max-width: 1400px;

      margin: auto;

      display: flex;
      align-items: center;
      justify-content: space-between;

      gap: 16px;

      flex-wrap: wrap;
    }

	.logo {
	  display: flex;
	  align-items: center;
	}

	.logo img {
	  height: 80px;
	  width: auto;
	  display: block;
	}

    nav {
      display: flex;
      align-items: center;

      gap: 16px;

      flex-wrap: wrap;
    }

    nav a {
      color: white;
      font-weight: 600;

      white-space: nowrap;
    }

    nav a:hover {
      text-decoration: underline;
    }

    /* SEARCH */

    #search {
      width: 100%;
      max-width: 320px;

      min-width: 0;

      flex: 1 1 260px;
    }

    .pagefind-ui {
      width: 100%;
      max-width: 320px;

      min-width: 0;
    }

    .pagefind-ui__search-input {
      width: 100% !important;

      min-width: 0 !important;

      box-sizing: border-box;
    }

    /* MAIN */

    main {
      max-width: 1400px;

      margin: auto;

      padding: 10px 30px;
    }

    /* FOOTER */

    footer {
      background: #f3f4f6;

      color: #111827;

      padding: 20px;

      text-align: center;

      font-size: 14px;

      margin-top: 40px;
    }

    /* CARDS */

    .card {
      border: 1px solid #e5e7eb;

      padding: 20px;

      border-radius: 10px;

      margin-bottom: 20px;

      transition: 0.2s ease;

      background: #ffffff;

      color: #111827;
    }

    .card h3 {
      margin-top: 0;
    }

    .card:hover {
      box-shadow:
        0 8px 20px rgba(0,0,0,0.06);

      transform: translateY(-3px);
    }

    /* MOBILE */

    @media (max-width: 768px) {
	
	  .logo img {
		height: 42px;
	  }

      .header-inner {
        flex-direction: column;

        align-items: stretch;
      }

      nav {
        justify-content: center;
      }

      #search,
      .pagefind-ui {
        max-width: 100%;
      }

      main {
        padding: 10px 15px;
      }

    }

  </style>

</head>

<body>

<header>

  <div class="header-inner">

	<a href="/" class="logo">
	  <img
		src="/images/logo.png"
		alt="Better Health Facts Research"
		width="286"
		height="80"
	  />
	</a>

    <Search />

    <nav>
      <a href="/">Home</a>
      <a href="/articles/">Articles</a>
      <a href="/about/">About</a>
      <a href="/disclaimer/">Disclaimer</a>
    </nav>

  </div>

</header>

<main>
  <slot />
</main>

<footer>
  © {new Date().getFullYear()} BetterHealthFacts Research.
</footer>

</body>
</html>