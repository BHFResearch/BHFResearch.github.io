---
import Search from '../components/Search.astro';
const { title = "Better Health Facts" } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="description" content={Astro.props.description || "Better Health Research Articles"} />

  <link rel="canonical" href={Astro.url} />

  <meta property="og:type" content="article" />
  <meta property="og:title" content={Astro.props.title} />
  <meta property="og:description" content={Astro.props.description} />
  <meta property="og:url" content={Astro.url} />
  
  <script async='async' crossorigin='anonymous' src='https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-0770728525587553'></script>
  
  <script defer src="https://cloud.umami.is/script.js" data-website-id="e41c2d07-e2b3-433b-a54f-53db54317699"></script>
	
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-08PH0RXVZP"></script>
	<script>
	  window.dataLayer = window.dataLayer || [];
	  function gtag(){dataLayer.push(arguments);}
	  gtag('js', new Date());

	  gtag('config', 'G-08PH0RXVZP');
  </script>
  
   
  <style>
    :root {
	  --bg: #020617;
	  --surface: #0f172a;
	  --surface-2: #111827;
	  --text: #f8fafc;
	  --muted: #94a3b8;
	  --primary: #38bdf8;
	  --border: rgba(255,255,255,0.08);
	  --radius: 22px;
	}

    body {
	  font-family:
		Inter,
		system-ui,
		sans-serif;

	  background:
		radial-gradient(
		  circle at top,
		  #0f172a,
		  #020617 60%
		);

	  color: var(--text);
	  margin: 0;
	}

    a {
      text-decoration: none;
      color: var(--primary);
    }

    header {
	  background: var(--primary);
	  color: white;
	  padding: 15px 20px;
	  position: sticky;
	  top: 0;
	  z-index: 1000;
	}

	nav {
	  margin-top: 8px;
	}

	nav a {
	  color: white;
	  margin-right: 18px;
	  font-weight: 500;
	}

	nav a:hover {
	  text-decoration: underline;
	}


    main {
	  max-width: 1400px;
	  margin: auto;
	  padding: 10px 30px;
	}

    footer {
      background: #f3f4f6;
      padding: 20px;
      text-align: center;
      font-size: 14px;
      margin-top: 40px;
    }
	
	.topbar {
	  display: flex;
	  justify-content: space-between;
	  align-items: center;
	  gap: 20px;
	  flex-wrap: wrap;
	}

	.logo {
	  font-size: 1.2rem;
	  font-weight: 700;
	}

	.search-wrap {
	  margin-top: 14px;
	}

    .card {
	  border: 1px solid #e5e7eb;
	  padding: 20px;
	  border-radius: 10px;
	  margin-bottom: 20px;
	  transition: 0.2s ease;
	  background: #ffffff;
	}

	.card h3 {
	  margin-top: 0;
	}

	.card:hover {
	  box-shadow: 0 8px 20px rgba(0,0,0,0.06);
	  transform: translateY(-3px);
	}
	
	#search {
	  max-width: 500px;
	}

    @media (max-width: 600px) {
      main {
        padding: 15px;
      }
	  #search {
		max-width: 100%;
	  }
    }
  </style>
</head>

<body>

<header>

  <div class="topbar">

    <strong class="logo">
      Better Health Research
    </strong>

    <nav>
      <a href="/">Home</a>
      <a href="/articles/">Articles</a>
      <a href="/about/">About</a>
      <a href="/disclaimer/">Disclaimer</a>
    </nav>

  </div>

  <div class="search-wrap">
    <Search />
  </div>

</header>

<main>
  <slot />
</main>

<footer>
  © {new Date().getFullYear()} BetterHealthFacts Research.
</footer>

</body>
</html>
