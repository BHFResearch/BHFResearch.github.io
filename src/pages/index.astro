---
import { getCollection } from 'astro:content';
import MainLayout from '../layouts/MainLayout.astro';

const articles = await getCollection('articles');

const sorted = articles.sort(
  (a, b) => new Date(b.data.pubDate) - new Date(a.data.pubDate)
);

const hero = sorted.find(article => article.data.featured);

const latest = hero
  ? sorted.filter(article => article.slug !== hero.slug)
  : sorted;
---

<MainLayout
  title="Better Health Research"
  description="Research-backed health articles exploring medicine, neuroscience, biology, and human health."
>

<section class="homepage">

  {hero && (
    <section class="hero">
      <a href={`/articles/${hero.slug}/`} class="hero-link">

        {hero.data.image && (
          <img
            src={hero.data.image}
            alt={hero.data.title}
            class="hero-image"
            loading="eager"
            fetchpriority="high"
          />
        )}

        <div class="hero-overlay">
          <span class="hero-category">
            {hero.data.category}
          </span>

          <h1>{hero.data.title}</h1>

          <p>{hero.data.description}</p>
        </div>

      </a>
    </section>
  )}

  {!hero && (
    <header class="page-header">
      <h1>Latest Health Articles</h1>
      <p>
        Research-based articles about health, neuroscience,
        medicine, and the human body.
      </p>
    </header>
  )}

  <section class="articles-grid">

    {latest.map(article => (
      <article class="article-card">

        <a href={`/articles/${article.slug}/`}>

          {article.data.image && (
            <img
              src={article.data.image}
              alt={article.data.title}
              class="article-image"
              loading="lazy"
            />
          )}

          <div class="article-content">

            <span class="article-category">
              {article.data.category}
            </span>

            <h2>{article.data.title}</h2>

            <p>{article.data.description}</p>

          </div>

        </a>

      </article>
    ))}

  </section>

  <nav class="pagination">
    <a href="/page/2/">Older Articles →</a>
  </nav>

</section>

<style>
  .homepage {
    display: flex;
    flex-direction: column;
    gap: 40px;
  }

  .page-header {
    padding: 10px 0 0;
  }

  .page-header h1 {
    font-size: clamp(2rem, 5vw, 3.5rem);
    margin-bottom: 10px;
    line-height: 1.1;
  }

  .page-header p {
    color: var(--muted);
    max-width: 700px;
    font-size: 1.05rem;
  }

  .hero {
    position: relative;
    border-radius: 24px;
    overflow: hidden;
    border: 1px solid rgba(255,255,255,0.08);
    background: #111827;
  }

  .hero-link {
    display: block;
    position: relative;
  }

  .hero-image {
    width: 100%;
    height: 70vh;
    object-fit: cover;
    display: block;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    justify-content: end;
    padding: 40px;
    background:
      linear-gradient(
        to top,
        rgba(0,0,0,0.88),
        rgba(0,0,0,0.25),
        rgba(0,0,0,0.05)
      );
  }

  .hero-category,
  .article-category {
    display: inline-block;
    margin-bottom: 12px;
    color: #7dd3fc;
    font-size: 0.8rem;
    letter-spacing: 1px;
    text-transform: uppercase;
    font-weight: 700;
  }

  .hero h1 {
    font-size: clamp(2rem, 5vw, 4.5rem);
    line-height: 1.05;
    margin: 0 0 15px;
    color: white;
    max-width: 900px;
  }

  .hero p {
    color: rgba(255,255,255,0.85);
    max-width: 700px;
    font-size: 1.1rem;
  }

  .articles-grid {
    display: grid;
    grid-template-columns: repeat(
      auto-fit,
      minmax(280px, 1fr)
    );
    gap: 24px;
  }

  .article-card {
    border-radius: 22px;
    overflow: hidden;
    background:
      linear-gradient(
        180deg,
        rgba(17,24,39,0.96),
        rgba(31,41,55,0.98)
      );

    border: 1px solid rgba(255,255,255,0.08);

    transition:
      transform 0.18s ease,
      border-color 0.18s ease,
      box-shadow 0.18s ease;

    will-change: transform;
  }

  .article-card:hover {
    transform: translateY(-5px);

    border-color: rgba(125,211,252,0.45);

    box-shadow:
      0 12px 30px rgba(0,0,0,0.28);
  }

  .article-card a {
    color: inherit;
    display: block;
    height: 100%;
  }

  .article-image {
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    display: block;
  }

  .article-content {
    padding: 22px;
  }

  .article-content h2 {
    margin: 0 0 12px;
    line-height: 1.25;
    font-size: 1.35rem;
  }

  .article-content p {
    color: #cbd5e1;
    line-height: 1.6;
    font-size: 0.96rem;
  }

  .pagination {
    display: flex;
    justify-content: center;
    margin-top: 10px;
  }

  .pagination a {
    padding: 14px 24px;
    border-radius: 999px;
    background: rgba(255,255,255,0.06);
    transition: 0.2s ease;
  }

  .pagination a:hover {
    background: rgba(125,211,252,0.12);
  }

  @media (max-width: 768px) {

    .hero-image {
      height: 55vh;
    }

    .hero-overlay {
      padding: 24px;
    }

    .article-content {
      padding: 18px;
    }

    .articles-grid {
      gap: 18px;
    }
  }
</style>